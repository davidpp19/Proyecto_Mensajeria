@using Mensajeria.Modelos
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="elec-page container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="elec-card shadow-lg">
                <div class="elec-card-header text-center py-3 border-0">
                    <h3 class="mb-0 text-white fw-bold">
                        <i class="bi bi-person-plus-fill me-2"></i>Crear Nueva Cuenta
                    </h3>
                </div>

                <div class="elec-card-body p-4 p-md-5">
                    <form asp-action="Register" asp-controller="Account" method="post">

                        <div class="row">
                            

                            <div class="col-md-6 ps-md-4 mt-4 mt-md-0">
                                <h5 class="elec-title mb-3 fs-5"><i class="bi bi-card-heading me-2"></i>Identificación de Usuario</h5>

                                <div class="mb-3">
                                    <label class="form-label text-white-50 small fw-bold">Nombre de Usuario (Username)</label>
                                    <input type="text" class="form-control elec-form-control rounded-3" name="nombreUsuario" required placeholder="Ej: jperez2026">
                                    <small class="text-white-50 opacity-75">Este será su nombre de acceso al sistema.</small>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label text-white-50 small fw-bold">Correo Electrónico</label>
                                    <input type="email" class="form-control elec-form-control rounded-3" name="email" required placeholder="usuario@ejemplo.com">
                                </div>
                            </div>
                        </div>

                        <hr class="my-4 border-secondary opacity-50">

                        <h5 class="elec-title mb-3 fs-5"><i class="bi bi-shield-lock-fill me-2"></i>Seguridad de la Cuenta</h5>

                        <div class="row justify-content-center">
                            <div class="col-md-8 mb-3">
                                <label class="form-label text-white-50 small fw-bold">Contraseña</label>
                                <input type="password" class="form-control elec-form-control rounded-3" name="password" required placeholder="Mínimo 8 caracteres">
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn elec-btn elec-btn-primary btn-lg rounded-3 fw-bold shadow-sm">
                                <i class="bi bi-person-check-fill me-2"></i>Crear Usuario
                            </button>
                            <a asp-action="Index" asp-controller="Home" class="btn elec-btn elec-btn-secondary rounded-3">
                                Cancelar
                            </a>
                        </div>

                        @if (ViewBag.ErrorMessage != null)
                        {
                            <div class="alert elec-alert elec-alert-danger mt-3 text-center border-0 shadow-sm">
                                <i class="bi bi-exclamation-octagon-fill me-2"></i>@ViewBag.ErrorMessage
                            </div>
                        }
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>