<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Mensajeria.MVC</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Mensajeria.MVC.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex">
        <aside class="bg-light border-end" style="width:260px; min-height:100vh;">
            <div class="p-3">
                <h5><a asp-area="" asp-controller="Home" asp-action="Index" class="text-decoration-none">Mensajeria</a></h5>
                <hr />
                <ul class="nav flex-column">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item mb-1">
                            <a class="nav-link" asp-controller="Conversaciones" asp-action="Index">Conversaciones</a>
                        </li>
                        @if (User.IsInRole("Administrador"))
                        {
                            <li class="nav-item mb-1">
                                <a class="nav-link" asp-controller="Mensajes" asp-action="Index">Mensajes</a>
                            </li>
                        }
                        
                        @if (User.IsInRole("Administrador"))
                        {
                            <li class="nav-item mb-1">
                                <a class="nav-link" asp-controller="Roles" asp-action="Index">Ver Roles</a>
                            </li>
                            <li class="nav-item mb-1">
                                <a class="nav-link" asp-controller="Usuarios" asp-action="Index">Ver Usuarios</a>
                            </li>
                            <li class="nav-item mb-1">
                                <a class="nav-link" asp-controller="EstadoMensajes" asp-action="Index">Estado Mensajes</a>
                            </li>
                        }
                        <li class="nav-item mt-3">
                            <div class="small text-muted">Conectado como</div>
                            <div class="fw-bold">@User.Identity.Name</div>
                            <form class="mt-2" asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Salir</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Index">Iniciar Sesión</a>
                        </li>
                    }
                </ul>
            </div>
        </aside>
        <main class="flex-grow-1 p-3">
            @RenderBody()

            <footer class="border-top footer text-muted mt-4">
                <div class="container-fluid">
                    &copy; 2026 - Mensajeria.MVC - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
            </footer>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
