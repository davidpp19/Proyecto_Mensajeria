@model Mensajeria.Modelos.Conversacion

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Conversacion</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Tipo_Conversacion" id="isGroup" /> Hacer un grupo
                </label>
            </div>
            @* Fecha de creación se establece automáticamente en el servidor, no mostrar input al usuario *@
            <div class="form-group">
                <label asp-for="Titulo_Conversacion" class="control-label"></label>
                <input asp-for="Titulo_Conversacion" class="form-control" id="Titulo_Conversacion" />
                <span asp-validation-for="Titulo_Conversacion" class="text-danger"></span>
            </div>
            <div class="form-group" id="participantsGroup">
                <label class="control-label">Seleccionar participantes</label>
                <div id="participantes">
                    @{
                        var usuarios = ViewBag.Usuarios as IEnumerable<Mensajeria.Modelos.Usuario>;
                        var currentUserId = ViewBag.CurrentUserId as int? ?? 0;
                        if (usuarios != null)
                        {
                            foreach (var u in usuarios)
                            {
                                if (u.Id == currentUserId) continue;
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="participantes" value="@u.Id" id="user_@u.Id" />
                                    <label class="form-check-label" for="user_@u.Id">@u.Nombre_Usuario (@u.Correo_Usuario)</label>
                                </div>
                            }
                        }
                    }
                </div>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Oculta el campo Titulo si no es grupo
        document.addEventListener('DOMContentLoaded', function() {
            const tipoCheckbox = document.getElementById('isGroup');
            const titulo = document.getElementById('Titulo_Conversacion');
            const participantsGroup = document.getElementById('participantsGroup');
            function toggleTitulo() {
                if (tipoCheckbox.checked) {
                    titulo.parentElement.style.display = '';
                    participantsGroup.style.display = '';
                } else {
                    titulo.parentElement.style.display = 'none';
                    titulo.value = '';
                    participantsGroup.style.display = 'none';
                    // clear selections
                    Array.from(document.getElementById('participantes').options).forEach(o => o.selected = false);
                }
            }
            tipoCheckbox.addEventListener('change', toggleTitulo);
            toggleTitulo();
        });
    </script>
}
