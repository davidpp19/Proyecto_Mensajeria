@model Mensajeria.Modelos.Conversacion

@{
    ViewData["Title"] = "Conversacion";
}

<div>
    <a asp-action="Index" class="btn btn-link">Back to List</a>
</div>

<div class="mt-4">
</div>

<h5>@ViewBag.TitleName</h5>
<div id="chatWindow" class="border rounded p-3 mb-2" style="height:50vh; overflow:auto;"></div>
<div id="composer" class="input-group">
    <input id="messageText" type="text" class="form-control" placeholder="Escribe un mensaje..." />
    <button id="sendBtn" class="btn btn-primary">Enviar</button>
</div>

@section Scripts {
    <script>
        const conversacionId = @Model.Id;
        let polling = true;

        async function fetchMessages() {
            try {
                const res = await fetch('/Mensajes/ByConversacion?conversacionId=' + conversacionId, { credentials: 'include' });
                if (!res.ok) throw new Error(res.statusText);
                const data = await res.json();
                renderMessages(data);
            } catch (err) {
                console.error('Error fetching messages', err);
            } finally {
                if (polling) setTimeout(fetchMessages, 1000);
            }
        }

        function renderMessages(messages) {
            const win = document.getElementById('chatWindow');
            win.innerHTML = '';
                messages.forEach(m => {
                        const el = document.createElement('div');
                        el.className = 'mb-2';
                        el.innerHTML = `<div class="d-flex justify-content-between"><div class="fw-bold">${m.remitente?.nombre_Usuario ?? m.remitenteId}</div><div class="small text-muted">${m.estado}</div></div><div>${m.contenido_Mensaje}</div><div class="small text-muted">${m.hora_Envio_Mensaje}</div>`;
                        win.appendChild(el);
                    });
            win.scrollTop = win.scrollHeight;
        }

        async function sendMessage() {
            const text = document.getElementById('messageText').value.trim();
            if (!text) return;
            const payload = { Contenido_Mensaje: text, ConversacionId: conversacionId, RemitenteId: @ViewBag.CurrentUserId };
            try {
                const res = await fetch('/Mensajes/CreateMessage', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload),
                    credentials: 'include'
                });
                const data = await res.json();
                if (data.success) {
                    document.getElementById('messageText').value = '';
                    // optimistically render
                    fetchMessages();
                } else {
                    alert('Error al enviar: ' + data.error);
                }
            } catch (err) {
                console.error(err);
            }
        }

        document.getElementById('sendBtn').addEventListener('click', sendMessage);
        // start polling
        fetchMessages();
    </script>
}
</div>
