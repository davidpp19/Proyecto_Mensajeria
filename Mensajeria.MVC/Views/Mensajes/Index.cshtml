@model IEnumerable<Mensajeria.Modelos.Mensaje>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Contenido_Mensaje)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ConversacionId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RemitenteId)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Contenido_Mensaje)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Conversacion.Titulo_Conversacion)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Remitente.Nombre_Usuario)
            </td>
            <td>
                @Html.ActionLink("Edit", "Edit", new { id=item.Id  }) |
                @Html.ActionLink("Details", "Details", new { id=item.Id }) |
                @Html.ActionLink("Delete", "Delete", new { id=item.Id })
            </td>
        </tr>
}
    </tbody>
</table>
