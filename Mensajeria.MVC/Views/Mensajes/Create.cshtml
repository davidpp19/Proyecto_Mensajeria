@model Mensajeria.Modelos.Mensaje

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Mensaje</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Contenido_Mensaje" class="control-label"></label>
                <input asp-for="Contenido_Mensaje" class="form-control" />
                <span asp-validation-for="Contenido_Mensaje" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ConversacionId" class="control-label"></label>
                <select asp-for="ConversacionId" class="form-control" asp-items="ViewBag.Conversaciones">
                    <option value="">-- Selección Tipo Conversación --</option>
                </select>
                <span asp-validation-for="ConversacionId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RemitenteId" class="control-label"></label>
                <select asp-for="RemitenteId" class="form-control" asp-items="ViewBag.Remitentes">
                    <option value="">-- Selección Remitentes --</option>
                </select>
                <span asp-validation-for="RemitenteId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
